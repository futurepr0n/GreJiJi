NODE_ENV=production
PORT=3000
HOST=0.0.0.0

DATABASE_PATH=./data/grejiji.sqlite
EVIDENCE_STORAGE_PATH=./data/dispute-evidence
EVIDENCE_MAX_BYTES=5242880
LISTING_PHOTO_STORAGE_PATH=./data/listing-photos
LISTING_PHOTO_MAX_BYTES=8388608
REQUEST_BODY_MAX_BYTES=1048576

AUTH_TOKEN_SECRET=change-me
AUTH_TOKEN_TTL_SECONDS=43200

RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_LISTINGS_WRITE_MAX=60
RATE_LIMIT_TRANSACTIONS_WRITE_MAX=60
RATE_LIMIT_DISPUTE_WRITE_MAX=40
RATE_LIMIT_ADMIN_JOBS_MAX=30
RATE_LIMIT_WEBHOOK_INTAKE_MAX=120
RISK_VELOCITY_WINDOW_MINUTES=30
RISK_VELOCITY_THRESHOLD=5
RISK_DISPUTE_WINDOW_HOURS=24
RISK_DISPUTE_THRESHOLD=3
LISTING_POLICY_BLOCKED_KEYWORDS=weapon,drugs,counterfeit,stolen
LISTING_POLICY_PRICE_HIGH_MULTIPLIER=5
LISTING_POLICY_PRICE_LOW_MULTIPLIER=0.2
LISTING_POLICY_PRICE_BASELINE_MIN_SAMPLES=3
LISTING_ABUSE_AUTO_HIDE_THRESHOLD=3
LAUNCH_CONTROL_ENV=production
LAUNCH_CONTROL_ROLLOUT_SALT=grejiji-launch-control
LAUNCH_FLAG_TRANSACTION_INITIATION_DEFAULT=true
LAUNCH_FLAG_PAYOUT_RELEASE_DEFAULT=false
LAUNCH_FLAG_DISPUTE_AUTO_TRANSITIONS_DEFAULT=false
LAUNCH_FLAG_MODERATION_AUTO_ACTIONS_DEFAULT=false
LAUNCH_CONTROL_AUTO_ROLLBACK_BURN_RATE_THRESHOLD=2
LAUNCH_CONTROL_AUTO_ROLLBACK_ERROR_RATE_THRESHOLD=0.05
LAUNCH_CONTROL_AUTO_ROLLBACK_WEBHOOK_FAILURE_THRESHOLD=5
LAUNCH_CONTROL_AUTO_ROLLBACK_FLAGS=transaction_initiation,payout_release,dispute_auto_transitions,moderation_auto_actions

REQUEST_LOG_ENABLED=true
ERROR_EVENT_LOG_FILE=./data/error-events.log

RELEASE_TIMEOUT_HOURS=72
SERVICE_FEE_FIXED_CENTS=0
SERVICE_FEE_PERCENT=0
SETTLEMENT_CURRENCY=USD

PAYMENT_PROVIDER=local
PAYMENT_LOCAL_DEFAULT_METHOD=pm_local_dev
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300
STRIPE_API_BASE_URL=https://api.stripe.com/v1
STRIPE_TIMEOUT_MS=10000
STRIPE_DEFAULT_PAYMENT_METHOD=pm_card_visa

# Deployment automation variables (used by scripts/deploy/*)
STAGING_BASE_URL=
STAGING_DATABASE_PATH=
STAGING_AUTH_TOKEN_SECRET=
STAGING_STRIPE_WEBHOOK_SECRET=
STAGING_DEPLOY_COMMAND=
STAGING_ROLLBACK_COMMAND=

PRODUCTION_BASE_URL=
PRODUCTION_DATABASE_PATH=
PRODUCTION_AUTH_TOKEN_SECRET=
PRODUCTION_STRIPE_WEBHOOK_SECRET=
PRODUCTION_DEPLOY_COMMAND=
PRODUCTION_ROLLBACK_COMMAND=
